{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  assignees: ['tharakadesilva'],
  extends: [
    'config:best-practices',
    ':disableRateLimiting',
    ':automergeMinor',
    ':automergePr',
    ':pinVersions',
  ],
  "hostRules": [
    {
      "matchHost": "github.com",
      "token": "{{ secrets.GITHUB_COM_TOKEN }}"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "at any time",
    ],
  },
  nix: {
    enabled: true,
  }
}
